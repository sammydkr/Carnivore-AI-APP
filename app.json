{
  "expo": {
    "name": "Carnivore-AI-APP",
    "slug": "Carnivore-AI-APP",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/ketovore-ai-logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/ketovore-ai-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Ketovore AI uses your camera so you can add a meal photo for wellness-focused meal analysis.",
        "NSPhotoLibraryUsageDescription": "Ketovore AI uses your photo library so you can choose a meal photo for wellness-focused meal analysis."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/ketovore-ai-logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font"
    ]
  }
}
